ANTHROPIC_API_KEY="sk-ant-api03-..."

# Local clones of the target repos — pipeline writes code directly into these
# Each dev sets their own paths; these are not committed
FE_REPO_PATH="/path/to/your/platform-monorepo"
BE_REPO_PATH="/path/to/your/backend-modulith"
JIRA_PATH="/path/to/your/jira"
CONFLUENCE_PATH="/path/to/your/confluence"

# SQLite checkpoint DB path (default: .checkpoints/sdlc.db — auto-created)
# Override for Docker: CHECKPOINT_DB_PATH="/data/checkpoints/sdlc.db"
# CHECKPOINT_DB_PATH=".checkpoints/sdlc.db"

# ── GitHub integration (Phase 3) ──────────────────────────────────────────────
# Create a fine-grained PAT at https://github.com/settings/tokens
# Required permissions: Contents (read+write), Pull requests (read+write)
# Leave blank to run in local-only mode (commits work, PRs are simulated)
GITHUB_TOKEN="ghp_..."
GITHUB_OWNER="cgarbacea"       # GitHub username or org that owns the repos
GITHUB_FE_REPO="youpage-fe"   # FE repo name (without owner prefix)
GITHUB_BE_REPO="youpage-be"   # BE repo name (without owner prefix)
GITHUB_BASE_BRANCH="main"     # Target branch for PRs (default: main)
